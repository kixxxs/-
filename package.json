{
  "name": "artist-manager",
  "version": "1.0.0",
  "description": "艺人管理系统",
  "author": "Artist Manager Team",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node -e \"['better-sqlite3','express','cors'].forEach(function(m){var p='node_modules/'+m;if(require('fs').existsSync(p))require('fs').rmSync(p,{recursive:true})})\"",
    "postbuild": "npm install",
    "build": "electron-builder --win",
    "export-share": "node export-share.js"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.0",
    "bootstrap": "^5.1.3",
    "bootstrap-icons": "^1.8.1",
    "chart.js": "^4.4.0",
    "sql.js": "^1.10.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "build": {
    "appId": "com.artist.manager",
    "productName": "艺人管理系统",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "艺人管理系统",
      "artifactName": "artist-manager-setup.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "db/**/*",
      "src/**/*",
      "build/**/*",
      "node_modules/**/*",
      "!db/**/*.db",
      "!db/**/*.db-shm",
      "!db/**/*.db-wal",
      "!node_modules/.cache",
      "!node_modules/**/node_modules"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ]
  }
}
